@page
@model TerytLoad.Pages.LoadTerytUlicPoprawkiModel
@{
    ViewData["Title"] = "Ładowanie TerytUlicPoprawki";
}

<h1>@ViewData["Title"]</h1>

<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0">📥 Ładowanie danych TerytUlicPoprawki z Excela do bazy</h5>
    </div>
    <div class="card-body">
        <p class="text-muted">
            Ta funkcja wczytuje dane z pliku 
            <code>AppData/Dictionaries/TerytUlicPoprawki.xlsx</code> 
            i ładuje je do tabeli <strong>TerytUlicPoprawki</strong> w bazie danych.
        </p>

        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle"></i>
            <strong>Uwaga:</strong> Ta operacja wyczyści wszystkie istniejące dane w tabeli TerytUlicPoprawki!
        </div>

        @if (!Model.IsProcessing)
        {
            <form method="post">
                <button type="submit" class="btn btn-primary btn-lg">
                    <i class="bi bi-upload"></i> Rozpocznij ładowanie
                </button>
            </form>
        }
        else
        {
            <div class="alert alert-info">
                <strong>Trwa ładowanie...</strong>
                <div class="progress mt-2">
                    <div class="progress-bar progress-bar-striped progress-bar-animated"
                         role="progressbar"
                         style="width: @Model.ProgressPercentage%"
                         aria-valuenow="@Model.ProgressPercentage"
                         aria-valuemin="0"
                         aria-valuemax="100">
                        @Model.ProgressPercentage%
                    </div>
                </div>
                <p class="mt-2 mb-0">@Model.CurrentOperation</p>
            </div>
        }
    </div>
</div>

@if (Model.ShowResults)
{
    <div class="card">
        <div class="card-header bg-success text-white">
            <h5 class="mb-0">✓ Zakończono ładowanie</h5>
        </div>
        <div class="card-body">
            <table class="table">
                <tbody>
                    <tr>
                        <th>Wczytano z Excela:</th>
                        <td>@Model.TotalCount</td>
                    </tr>
                    <tr>
                        <th>Wstawiono do bazy:</th>
                        <td class="text-success fw-bold">@Model.InsertedCount</td>
                    </tr>
                    <tr>
                        <th>Status:</th>
                        <td>
                            @if (Model.InsertedCount == Model.TotalCount)
                            {
                                <span class="text-success fw-bold">✓ Wszystkie dane zostały załadowane pomyślnie</span>
                            }
                            else
                            {
                                <span class="text-warning fw-bold">⚠️ Część danych nie została załadowana</span>
                            }
                        </td>
                    </tr>
                </tbody>
            </table>

            <div class="alert alert-info mt-3">
                <i class="bi bi-info-circle"></i>
                Szczegółowy log: <code>@Model.LogFilePath</code>
            </div>

            <a asp-page="/Index" class="btn btn-primary mt-2">
                <i class="bi bi-arrow-left"></i> Powrót do strony głównej
            </a>
        </div>
    </div>
}

@section Scripts {
    <script>
        // Auto-refresh co 2 sekundy podczas przetwarzania
        @if (Model.IsProcessing)
        {
            <text>
            setTimeout(function() {
                location.reload();
            }, 2000);
            </text>
        }
    </script>
}