@page
@model TerytLoad.Pages.SzukajModel
@{
    ViewData["Title"] = "Wyszukiwanie kodów pocztowych";
}

<div class="container mt-4">
    <h1 class="mb-4">
        <i class="bi bi-search"></i> Wyszukiwanie kodów pocztowych
    </h1>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form method="post">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label asp-for="SearchParams.Kod" class="form-label">
                            <i class="bi bi-mailbox"></i> Kod pocztowy
                        </label>
                        <input asp-for="SearchParams.Kod" class="form-control form-control-sm" placeholder="np. 00-001" />
                        <small class="form-text text-muted">Opcjonalny</small>
                        <span asp-validation-for="SearchParams.Kod" class="text-danger small"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="SearchParams.Miasto" class="form-label">
                            <i class="bi bi-geo-alt"></i> Miejscowość
                        </label>
                        <input asp-for="SearchParams.Miasto" class="form-control form-control-sm" placeholder="np. Warszawa" />
                        <small class="form-text text-muted">Opcjonalna</small>
                        <span asp-validation-for="SearchParams.Miasto" class="text-danger small"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="SearchParams.Ulica" class="form-label">
                            <i class="bi bi-signpost-2"></i> Ulica
                        </label>
                        <input asp-for="SearchParams.Ulica" class="form-control form-control-sm" placeholder="np. Marszałkowska" />
                        <small class="form-text text-muted">Opcjonalna</small>
                    </div>

                    <div class="col-md-2">
                        <label asp-for="SearchParams.NumerDomu" class="form-label">
                            <i class="bi bi-house-door"></i> Nr domu
                        </label>
                        <input asp-for="SearchParams.NumerDomu" class="form-control form-control-sm" placeholder="15" />
                        <small class="form-text text-muted">Opcjonalny</small>
                    </div>

                    <div class="col-md-1">
                        <label asp-for="SearchParams.NumerMieszkania" class="form-label">
                            <i class="bi bi-door-closed"></i> M.
                        </label>
                        <input asp-for="SearchParams.NumerMieszkania" class="form-control form-control-sm" placeholder="10" />
                        <small class="form-text text-muted">Opcj.</small>
                    </div>
                </div>

                <div class="row mt-3">
                    <div class="col-12">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-search"></i> Szukaj
                        </button>
                        <button type="submit" asp-page-handler="Clear" class="btn btn-secondary ms-2">
                            <i class="bi bi-x-circle"></i> Wyczyść
                        </button>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger mt-3 mb-0" role="alert">
                        <i class="bi bi-exclamation-triangle"></i> @Model.ErrorMessage
                    </div>
                }
            </form>
        </div>
    </div>

    @if (Model.Wynik != null)
    {
        var w = Model.Wynik;
        var statusClass = w.Status == AddressLibrary.Services.AddressSearch.AddressSearchStatus.Success
            ? "success" : "warning";
        var statusIcon  = w.Status == AddressLibrary.Services.AddressSearch.AddressSearchStatus.Success
            ? "check-circle" : "exclamation-circle";

        <div class="card shadow-sm mt-3">
            <div class="card-header bg-@statusClass text-white">
                <h5 class="mb-0">
                    <i class="bi bi-@statusIcon"></i>
                    @w.Status
                    @if (!string.IsNullOrEmpty(w.Message)) { <small class="ms-2">— @w.Message</small> }
                </h5>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-3">Kod pocztowy</dt>
                    <dd class="col-sm-9 fw-bold fs-5">@(w.KodPocztowy?.Kod ?? "—")</dd>

                    <dt class="col-sm-3">Miejscowość</dt>
                    <dd class="col-sm-9">@(w.Miasto?.Nazwa ?? "—")</dd>

                    <dt class="col-sm-3">Ulica</dt>
                    <dd class="col-sm-9">
                        @if (w.Ulica != null)
                        {
                            @if (!string.IsNullOrEmpty(w.Ulica.Nazwa2))
                            {
                                <span class="text-muted small">@w.Ulica.Nazwa2 </span>
                            }
                            <span>@w.Ulica.Nazwa1</span>
                        }
                        else { <span class="text-muted fst-italic">brak ulicy</span> }
                    </dd>

                    <dt class="col-sm-3">Numery w kodzie</dt>
                    <dd class="col-sm-9">
                        <small class="text-muted">@(w.KodPocztowy?.Numery ?? "wszystkie")</small>
                    </dd>

                    @if (w.Miasto?.Gmina != null)
                    {
                        <dt class="col-sm-3">Gmina / Powiat / Woj.</dt>
                        <dd class="col-sm-9">
                            @w.Miasto.Gmina.Nazwa
                            @if (w.Miasto.Gmina.Powiat != null)
                            {
                                <span class="text-muted"> / @w.Miasto.Gmina.Powiat.Nazwa</span>
                            }
                            @if (w.Miasto.Gmina.Powiat?.Wojewodztwo != null)
                            {
                                <span class="text-muted"> / @w.Miasto.Gmina.Powiat.Wojewodztwo.Nazwa</span>
                            }
                        </dd>
                    }

                    @if (w.Status == AddressLibrary.Services.AddressSearch.AddressSearchStatus.Success)
                    {
                        <dt class="col-sm-3">Metoda dopasowania</dt>
                        <dd class="col-sm-9">
                            <small>Miasto: @w.CityMatchingMethod | Ulica: @w.StreetMatchingMethod</small>
                        </dd>
                    }

                    @if (!string.IsNullOrEmpty(w.DiagnosticInfo))
                    {
                        <dt class="col-sm-3">Diagnostyka</dt>
                        <dd class="col-sm-9">
                            <pre class="mb-0 small text-muted" style="white-space: pre-wrap;">@w.DiagnosticInfo</pre>
                        </dd>
                    }

                    @if (w.AlternativeMatches?.Count > 0)
                    {
                        <dt class="col-sm-3">Alternatywy (@w.AlternativeMatches.Count)</dt>
                        <dd class="col-sm-9">
                            @foreach (var alt in w.AlternativeMatches)
                            {
                                <span class="badge bg-secondary me-1">@alt.Kod</span>
                            }
                        </dd>
                    }
                </dl>
            </div>
        </div>
    }
    else if (Model.Wynik == null && Model.ErrorMessage == null && Request.Method == "POST")
    {
        <div class="alert alert-warning mt-3">
            <i class="bi bi-exclamation-circle"></i> Brak wyników dla podanych kryteriów.
        </div>
    }

    <div class="card mt-4 border-info">
        <div class="card-header bg-info text-white">
            <h6 class="mb-0"><i class="bi bi-info-circle"></i> Instrukcja wyszukiwania</h6>
        </div>
        <div class="card-body">
            <p class="mb-2"><strong>Możliwe scenariusze:</strong></p>
            <ul class="mb-2">
                <li><strong>Kod + Ulica + Numer:</strong> Znajdź dokładny adres</li>
                <li><strong>Miejscowość + Ulica + Numer:</strong> Znajdź kod pocztowy</li>
                <li><strong>Kod + Miejscowość:</strong> Wszystkie adresy w miejscowości</li>
                <li><strong>Miejscowość (bez ulicy):</strong> Kody bez konkretnej ulicy</li>
            </ul>
            <p class="mb-0 small">
                <strong>Format numerów:</strong> <code>1-5</code>, <code>7-9(n)</code> (nieparzyste), 
                <code>2-10(p)</code> (parzyste), <code>11-DK</code> (do końca)
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}