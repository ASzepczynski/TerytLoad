@page
@model TerytLoad.Pages.LoadPostalCodesModel
@{
    ViewData["Title"] = "Ładowanie kodów pocztowych";
}

<div class="container mt-4">
    <h1 class="mb-4">📮 Ładowanie kodów pocztowych</h1>

    @if (!string.IsNullOrEmpty(Model.Message) && Model.ShowResults)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <h4 class="alert-heading">✅ Wyniki ładowania</h4>
            <hr>
            <pre style="white-space: pre-wrap; margin: 0; font-family: 'Courier New', monospace; font-size: 14px;">@Model.Message</pre>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Progress Bar (ukryty domyślnie) -->
    <div id="progressContainer" style="display: none;" class="mb-4">
        <div class="alert alert-info">
            <h4 id="progressTitle">⏳ Trwa ładowanie kodów pocztowych...</h4>
            <div class="progress mt-3" style="height: 30px;">
                <div id="progressBar" 
                     class="progress-bar progress-bar-striped progress-bar-animated" 
                     role="progressbar" 
                     style="width: 0%;" 
                     aria-valuenow="0" 
                     aria-valuemin="0" 
                     aria-valuemax="100">
                    0%
                </div>
            </div>
            <div id="progressMessage" class="mt-3" style="font-family: monospace; font-size: 14px; white-space: pre-wrap;">
                Inicjalizacja...
            </div>
            <div id="progressStats" class="mt-2 text-muted">
                <small>
                    Przetworzono: <strong><span id="processedCount">0</span></strong> / 
                    <strong><span id="totalCount">0</span></strong>
                </small>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header bg-primary text-white">
            <h3 class="mb-0">📬 Załaduj kody pocztowe z danych PNA</h3>
        </div>
        <div class="card-body">
            <p class="card-text">Kliknij poniżej, aby:</p>
            <ol>
                <li>Wyczyścić istniejące kody pocztowe</li>
                <li>Załadować kody pocztowe na podstawie danych z tabeli <strong>Pna</strong></li>
                <li>Połączyć je z miejscowościami i ulicami</li>
            </ol>
            <p class="text-warning">
                <strong>⚠️ Uwaga:</strong> Aby ta operacja się powiodła, musisz wcześniej:
            </p>
            <ul class="text-warning">
                <li>Załadować dane TERYT (strona "Baza danych" lub "Ładowanie PDF")</li>
                <li>Zbudować strukturę hierarchiczną (strona "Struktura hierarchiczna")</li>
            </ul>
            <p class="text-muted">
                <strong>Informacja:</strong> Proces może potrwać kilka minut w zależności od ilości danych.
            </p>
            <form method="post" asp-page-handler="Load" id="loadForm">
                <button type="submit" class="btn btn-primary btn-lg" id="loadButton">
                    <span>📤</span> Załaduj kody pocztowe
                </button>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-header bg-info text-white">
            <h5 class="mb-0">ℹ️ Informacje</h5>
        </div>
        <div class="card-body">
            <p><strong>Źródło danych:</strong> Tabela <strong>Pna</strong> (dane z PDF)</p>
            <p><strong>Tabela docelowa:</strong> <strong>KodyPocztowe</strong></p>
            <p class="mb-0"><strong>Proces obejmuje:</strong></p>
            <ul class="mb-0">
                <li>Parsowanie zakresów numerów budynków</li>
                <li>Dopasowywanie miejscowości po symbolach TERYT</li>
                <li>Dopasowywanie ulic po nazwach w kontekście miejscowości</li>
                <li>Automatyczne korekty błędnych danych (miejscowości i ulice)</li>
                <li>Obsługę błędów i brakujących danych</li>
            </ul>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@latest/dist/browser/signalr.min.js"></script>
    <script>
        // Połączenie SignalR
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/progressHub")
            .withAutomaticReconnect()
            .configureLogging(signalR.LogLevel.Information)
            .build();

        // Obsługa otrzymania postępu
        connection.on("ReceiveProgress", (operation, current, total, message) => {
            console.log("ReceiveProgress:", operation, current, total, message);

            if (operation === "postal-codes") {
                const progressContainer = document.getElementById("progressContainer");
                const progressBar = document.getElementById("progressBar");
                const progressMessage = document.getElementById("progressMessage");
                const progressTitle = document.getElementById("progressTitle");
                const processedCount = document.getElementById("processedCount");
                const totalCount = document.getElementById("totalCount");
                const loadButton = document.getElementById("loadButton");

                // Pokaż kontener postępu
                progressContainer.style.display = "block";

                // Oblicz procent
                const percentage = total > 0 ? Math.round((current / total) * 100) : 0;
                
                // Aktualizuj pasek postępu
                progressBar.style.width = percentage + "%";
                progressBar.textContent = percentage + "%";
                progressBar.setAttribute("aria-valuenow", percentage);

                // Aktualizuj komunikat (zachowaj formatowanie dla podsumowania)
                progressMessage.textContent = message;
                
                // Aktualizuj statystyki
                processedCount.textContent = current.toLocaleString('pl-PL');
                totalCount.textContent = total.toLocaleString('pl-PL');

                // Zmień wygląd gdy zakończono
                if (percentage >= 100 || message.startsWith("✓")) {
                    progressBar.classList.remove("progress-bar-animated", "progress-bar-striped");
                    progressBar.classList.add("bg-success");
                    progressTitle.textContent = "✅ Zakończono pomyślnie!";
                    loadButton.disabled = false;
                    
                    // Zmień kontener na success
                    progressContainer.querySelector('.alert').classList.remove('alert-info');
                    progressContainer.querySelector('.alert').classList.add('alert-success');
                }

                // Obsługa błędów
                if (message.startsWith("❌")) {
                    progressBar.classList.remove("progress-bar-animated", "progress-bar-striped");
                    progressBar.classList.add("bg-danger");
                    progressTitle.textContent = "❌ Wystąpił błąd";
                    loadButton.disabled = false;
                    
                    // Zmień kontener na danger
                    progressContainer.querySelector('.alert').classList.remove('alert-info');
                    progressContainer.querySelector('.alert').classList.add('alert-danger');
                }
            }
        });

        // Start połączenia
        connection.start()
            .then(() => {
                console.log("SignalR Connected");
            })
            .catch(err => {
                console.error("SignalR Connection Error: ", err);
                alert("Nie można połączyć z serwerem SignalR. Odśwież stronę i spróbuj ponownie.");
            });

        // Obsługa wysyłki formularza
        document.getElementById("loadForm").addEventListener("submit", function(e) {
            const loadButton = document.getElementById("loadButton");
            const progressContainer = document.getElementById("progressContainer");
            
            // Wyłącz przycisk
            loadButton.disabled = true;
            
            // Pokaż kontener postępu
            progressContainer.style.display = "block";
            
            // Zresetuj pasek postępu
            const progressBar = document.getElementById("progressBar");
            progressBar.style.width = "0%";
            progressBar.textContent = "0%";
            progressBar.classList.add("progress-bar-animated", "progress-bar-striped");
            progressBar.classList.remove("bg-success", "bg-danger");
            
            // Reset kontenera do info
            const alertDiv = progressContainer.querySelector('.alert');
            alertDiv.classList.remove('alert-success', 'alert-danger');
            alertDiv.classList.add('alert-info');
            
            document.getElementById("progressTitle").textContent = "⏳ Trwa ładowanie kodów pocztowych...";
            document.getElementById("progressMessage").textContent = "Wysyłanie żądania do serwera...";
        });
    </script>
}