@page
@model TerytLoad.Pages.VerifyAddressesModel
@{
    ViewData["Title"] = "Masowa weryfikacja adresów";
}

<div class="container mt-4">
    <h1 class="mb-4">
        <i class="bi bi-check2-square"></i> Masowa weryfikacja adresów
    </h1>

    <div class="alert alert-info">
        <h5 class="alert-heading"><i class="bi bi-info-circle"></i> Informacje</h5>
        <p>Ta funkcja umożliwia masową weryfikację adresów z pliku tekstowego.</p>
        <ul>
            <li><strong>Format pliku wejściowego:</strong> Kolumny rozdzielone znakiem <code>|</code></li>
            <li><strong>Kolumny:</strong> ID|Kod|Miasto|Ulica|Budynek|Lokal|Wojewodztwo|Powiat|Gmina</li>
            <li><strong>Plik wynikowy:</strong> Zostanie utworzony w tym samym folderze z sufiksem <code>_wynik.txt</code></li>
            <li><strong>Format wyniku:</strong> ID, status (SUKCES/BRAK), pary kolumn (wynik + źródło)</li>
            <li><strong>Różnice:</strong> Kolumny źródłowe ze znacznikiem <code>*</code> oznaczają niezgodność z wynikiem</li>
        </ul>
    </div>

    <!-- Pasek postępu -->
    <div id="progress-container" style="display: none;" class="mb-4">
        <div class="card">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <span class="spinner-border spinner-border-sm me-2" id="progress-spinner"></span>
                    Postęp weryfikacji
                </h5>
                <span id="elapsed-time" class="badge bg-light text-dark fs-6">
                    <i class="bi bi-stopwatch"></i> 0:00
                </span>
            </div>
            <div class="card-body">
                <div class="progress mb-3" style="height: 30px;">
                    <div id="progress-bar" class="progress-bar progress-bar-striped progress-bar-animated"
                         role="progressbar" style="width: 0%;" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100">
                        <span id="progress-percentage">0%</span>
                    </div>
                </div>
                <pre id="progress-message" style="white-space: pre-wrap; font-family: 'Courier New', monospace; font-size: 14px; margin: 0; max-height: 400px; overflow-y: auto;"></pre>
            </div>
        </div>
    </div>

    <!-- Wynik końcowy -->
    <div id="result-container" style="display: none;" class="mb-4">
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <pre id="result-message" style="white-space: pre-wrap; margin: 0; font-family: 'Courier New', monospace; font-size: 14px;"></pre>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header bg-primary text-white">
            <h3 class="mb-0"><i class="bi bi-file-earmark-text"></i> Weryfikacja adresów z pliku</h3>
        </div>
        <div class="card-body">
            <form method="post" asp-page-handler="Verify">
                <div class="mb-3">
                    <label asp-for="InputFilePath" class="form-label">
                        <i class="bi bi-folder2-open"></i> Ścieżka do pliku źródłowego
                    </label>
                    <input asp-for="InputFilePath" class="form-control" placeholder="AppData/Address/adresy.txt" />
                    <small class="form-text text-muted">
                        Ścieżka względna od katalogu projektu. Domyślnie: <code>AppData/Address/adresy.txt</code>
                    </small>
                    <span asp-validation-for="InputFilePath" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary btn-lg" id="verifyButton">
                    <i class="bi bi-play-fill"></i>
                    <span>Rozpocznij weryfikację</span>
                </button>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-header bg-secondary text-white">
            <h5 class="mb-0"><i class="bi bi-journal-text"></i> Przykładowy format pliku wejściowego</h5>
        </div>
        <div class="card-body">
            <pre class="mb-0" style="font-size: 12px; background-color: #f8f9fa; padding: 1rem; border-radius: 0.25rem;">ID|Kod|Miasto|Ulica|Budynek|Lokal|Wojewodztwo|Powiat|Gmina
A1475445|34-400|NOWY TARG||1||||
A1701425|05-800|PRUSZKÓW||13||||
TU1418430|37-543|LASZKI||27||PODKARPACKIE|JAROSŁAWSKI|LASZKI
A1394|31-413|Krakow||1|67|MAŁOPOLSKIE|KRAKÓW|KRAKÓW</pre>
        </div>
    </div>

    <div class="mt-4">
        <a asp-page="/Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Powrót do strony głównej
        </a>
        <a asp-page="/Szukaj" class="btn btn-info ms-2">
            <i class="bi bi-search"></i> Pojedyncze wyszukiwanie
        </a>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@latest/dist/browser/signalr.min.js"></script>
    <script>
        // --- SignalR ---
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/progressHub")
            .withAutomaticReconnect()
            .configureLogging(signalR.LogLevel.Warning)
            .build();

        connection.on("ReceiveProgress", (operation, current, total, message) => {
            if (operation !== "verify-addresses") return;

            const container   = document.getElementById("progress-container");
            const bar         = document.getElementById("progress-bar");
            const pct         = document.getElementById("progress-percentage");
            const msgPre      = document.getElementById("progress-message");
            const resultBox   = document.getElementById("result-container");
            const resultPre   = document.getElementById("result-message");
            const btn         = document.getElementById("verifyButton");

            container.style.display = "block";

            const percent = total > 0 ? Math.round(current / total * 100) : 0;
            bar.style.width     = percent + "%";
            bar.setAttribute("aria-valuenow", percent);
            pct.textContent     = percent + "%";
            msgPre.textContent  = message;

            // Auto-scroll wiadomości w dół
            msgPre.scrollTop = msgPre.scrollHeight;

            const isFinished = percent >= 100 || message.startsWith("✅");
            const isError    = message.startsWith("❌");

            if (isFinished || isError) {
                stopTimer();
                bar.classList.remove("progress-bar-animated", "progress-bar-striped");
                bar.classList.add(isError ? "bg-danger" : "bg-success");
                document.getElementById("progress-spinner").style.display = "none";

                // Pokaż wynik końcowy
                resultBox.style.display = "block";
                resultPre.textContent   = message;
                resultBox.querySelector(".alert").className =
                    "alert " + (isError ? "alert-danger" : "alert-success") + " alert-dismissible fade show";

                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-play-fill"></i> Rozpocznij weryfikację';
            }
        });

        connection.onreconnecting(() => {
            document.getElementById("progress-message").textContent += "\n⚠️ Reconnecting do SignalR...";
        });

        async function startConnection() {
            try {
                await connection.start();
                console.log("SignalR połączony");
            } catch (err) {
                console.error("SignalR błąd połączenia:", err);
                setTimeout(startConnection, 3000);
            }
        }

        startConnection();

        // --- Timer ---
        let timerInterval = null;
        let startTime     = null;

        function startTimer() {
            startTime = Date.now();
            timerInterval = setInterval(() => {
                const secs    = Math.floor((Date.now() - startTime) / 1000);
                const minutes = Math.floor(secs / 60);
                const seconds = String(secs % 60).padStart(2, '0');
                document.getElementById("elapsed-time").innerHTML =
                    '<i class="bi bi-stopwatch"></i> ' + minutes + ':' + seconds;
            }, 1000);
        }

        function stopTimer() {
            if (timerInterval) {
                clearInterval(timerInterval);
                timerInterval = null;
            }
        }

        // --- Form submit ---
        document.querySelector('form').addEventListener('submit', function () {
            document.getElementById("progress-container").style.display = "block";
            document.getElementById("result-container").style.display  = "none";
            document.getElementById("progress-message").textContent    = "⏳ Oczekiwanie na start procesu...";
            document.getElementById("elapsed-time").innerHTML          = '<i class="bi bi-stopwatch"></i> 0:00';
            document.getElementById("progress-spinner").style.display  = "inline-block";

            const bar = document.getElementById("progress-bar");
            bar.style.width = "0%";
            bar.classList.remove("bg-success", "bg-danger");
            bar.classList.add("progress-bar-animated", "progress-bar-striped");
            document.getElementById("progress-percentage").textContent = "0%";

            const btn = document.getElementById("verifyButton");
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Przetwarzanie...';

            startTimer();
        });
    </script>
}
