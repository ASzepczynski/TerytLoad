@page
@model TerytLoad.Pages.BuildHierarchyModel
@{
    ViewData["Title"] = "Ładowanie hierarchii";
}

<div class="container mt-4">
    <h1 class="mb-4"><i class="bi bi-diagram-3-fill"></i> Ładowanie hierarchii</h1>

    <!-- Pasek postępu -->
    <div id="progressContainer" style="display: none;" class="mb-4">
        <div class="alert alert-info">
            <h4 id="progressTitle"><i class="bi bi-hourglass-split"></i> Trwa ładowanie hierarchii...</h4>
            <div class="progress mt-3" style="height: 30px;">
                <div id="progressBar"
                     class="progress-bar progress-bar-striped progress-bar-animated"
                     role="progressbar"
                     style="width: 0%;"
                     aria-valuenow="0"
                     aria-valuemin="0"
                     aria-valuemax="100">
                    0%
                </div>
            </div>
            <div id="progressMessage" class="mt-3" style="font-family: monospace; font-size: 14px; white-space: pre-wrap;">
                Inicjalizacja...
            </div>
            <div id="progressStats" class="mt-2 text-muted">
                <small>Krok: <strong><span id="currentStep">0</span></strong> / <strong><span id="totalSteps">10</span></strong></small>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header bg-warning text-dark">
            <h3 class="mb-0"><i class="bi bi-diagram-3-fill"></i> Załaduj hierarchię</h3>
        </div>
        <div class="card-body">
            <p class="card-text">Kliknij poniżej, aby uruchomić pełne ładowanie hierarchii w dwóch krokach:</p>
            <ol>
                <li><strong>Słowniki ulic</strong> – ładowanie TerytUlicPoprawki i generowanie TypyUlic</li>
                <li><strong>Struktura hierarchiczna</strong> – województwa, powiaty, gminy, miejscowości, ulice</li>
            </ol>
            <p class="text-danger">
                <strong>UWAGA:</strong> Ta operacja usunie istniejące dane hierarchiczne i zbuduje je od nowa. Proces może potrwać kilka minut.
            </p>
            <form method="post" asp-page-handler="Build" id="buildForm">
                <button type="submit" class="btn btn-warning btn-lg" id="buildButton">
                    <i class="bi bi-diagram-3-fill"></i> Załaduj hierarchię
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@latest/dist/browser/signalr.min.js"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/progressHub")
            .withAutomaticReconnect()
            .configureLogging(signalR.LogLevel.Information)
            .build();

        connection.on("ReceiveProgress", (operation, current, total, message) => {
            if (operation !== "build-hierarchy") return;

            const progressContainer = document.getElementById("progressContainer");
            const progressBar = document.getElementById("progressBar");
            const progressMessage = document.getElementById("progressMessage");
            const progressTitle = document.getElementById("progressTitle");
            const buildButton = document.getElementById("buildButton");

            progressContainer.style.display = "block";

            const percentage = total > 0 ? Math.round((current / total) * 100) : 0;
            progressBar.style.width = percentage + "%";
            progressBar.textContent = percentage + "%";
            progressBar.setAttribute("aria-valuenow", percentage);
            progressMessage.textContent = message;
            document.getElementById("currentStep").textContent = current;
            document.getElementById("totalSteps").textContent = total;

            if (percentage >= 100 || message.startsWith("SUKCES_OK")) {
                progressBar.classList.remove("progress-bar-animated", "progress-bar-striped");
                progressBar.classList.add("bg-success");
                progressTitle.innerHTML = '<i class="bi bi-check-circle-fill"></i> Zakończono pomyślnie!';
                buildButton.disabled = false;
                progressContainer.querySelector('.alert').classList.remove('alert-info', 'alert-danger');
                progressContainer.querySelector('.alert').classList.add('alert-success');
            } else if (message.startsWith("BLAD_ERR")) {
                progressBar.classList.remove("progress-bar-animated", "progress-bar-striped");
                progressBar.classList.add("bg-danger");
                progressTitle.innerHTML = '<i class="bi bi-exclamation-triangle-fill"></i> Wystąpił błąd';
                buildButton.disabled = false;
                progressContainer.querySelector('.alert').classList.remove('alert-info', 'alert-success');
                progressContainer.querySelector('.alert').classList.add('alert-danger');
                console.error("BuildHierarchy error:", message);
            }
        });

        connection.start()
            .catch(err => {
                console.error("SignalR Connection Error: ", err);
                alert("Nie można połączyć z serwerem SignalR. Odśwież stronę i spróbuj ponownie.");
            });

        document.getElementById("buildForm").addEventListener("submit", function () {
            const buildButton = document.getElementById("buildButton");
            const progressContainer = document.getElementById("progressContainer");
            const progressBar = document.getElementById("progressBar");

            buildButton.disabled = true;
            progressContainer.style.display = "block";
            progressBar.style.width = "0%";
            progressBar.textContent = "0%";
            progressBar.classList.add("progress-bar-animated", "progress-bar-striped");
            progressBar.classList.remove("bg-success", "bg-danger");

            const alertDiv = progressContainer.querySelector('.alert');
            alertDiv.classList.remove('alert-success', 'alert-danger');
            alertDiv.classList.add('alert-info');

            document.getElementById("progressTitle").innerHTML = '<i class="bi bi-hourglass-split"></i> Trwa ładowanie hierarchii...';
            document.getElementById("progressMessage").textContent = "Wysyłanie żądania do serwera...";
        });
    </script>
}
