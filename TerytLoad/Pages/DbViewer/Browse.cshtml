@page
@model TerytLoad.Pages.DbViewer.BrowseModel
@using TerytLoad.Pages.DbViewer
@{
    ViewData["Title"] = Model.Config?.DisplayName ?? "Przeglądarka";
}

<div class="container-fluid mt-4">
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>@Model.Config?.Icon @Model.Config?.DisplayName</h2>
    <a href="/DbViewer" class="btn btn-secondary">← Powrót do menu</a>
</div>

@* Kontekst rodzica (jeśli przeglądamy relację dziecko) *@
@if (!string.IsNullOrEmpty(Model.ParentEntity) && Model.ParentId.HasValue)
{
    <div class="alert alert-info">
        <strong>@ViewerRegistry.GetConfig(Model.ParentEntity)?.Icon @ViewerRegistry.GetConfig(Model.ParentEntity)?.DisplayName:</strong> 
        @Model.ParentDescription
        <span class="text-muted">(ID: @Model.ParentId)</span>
        <a href="/DbViewer/Browse?entity=@Model.ParentEntity" class="btn btn-sm btn-outline-primary ms-3">
            ← Powrót do @ViewerRegistry.GetConfig(Model.ParentEntity)?.DisplayName
        </a>
    </div>
}

@if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Formularz filtrowania -->
    <div class="card mb-4">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">🔍 Filtrowanie</h5>
        </div>
        <div class="card-body">
            <form method="get" class="row g-3">
                <input type="hidden" name="entity" value="@Model.Entity" />
                <div class="col-md-3">
                    <label class="form-label">Kolumna</label>
                    <select name="FilterColumn" class="form-select" asp-for="FilterColumn">
                        <option value="">-- Wybierz kolumnę --</option>
                        @foreach (var col in Model.Config?.Columns.Where(c => c.IsFilterable) ?? Enumerable.Empty<ColumnConfig>())
                        {
                            <option value="@col.PropertyName">@col.DisplayName</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Operator</label>
                    <select name="FilterOperator" class="form-select" asp-for="FilterOperator">
                        <option value="contains">Zawiera</option>
                        <option value="notcontains">Nie zawiera</option>
                        <option value="equals">Równa się</option>
                        <option value="notequals">Nie równa się</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Wartość</label>
                    <input type="text" name="FilterValue" class="form-control" asp-for="FilterValue" placeholder="Wprowadź wartość...">
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary me-2">Filtruj</button>
                    <a href="/DbViewer/Browse?entity=@Model.Entity" class="btn btn-secondary">Wyczyść</a>
                </div>
            </form>
        </div>
    </div>

    <!-- Tabela wyników -->
    <div class="card">
        <div class="card-header">
            <h5 class="mb-0">
                Tabela: @Model.Config?.Description
                <span class="text-muted">(@Model.Items.Count rekordów
                @if (string.IsNullOrEmpty(Model.FilterColumn) || string.IsNullOrEmpty(Model.FilterValue))
                {
                    <text>- maksymalnie 100 pozycji, użyj filtra aby zobaczyć więcej</text>
                }
                )</span>
            </h5>
        </div>
        <div class="card-body">
            @if (string.IsNullOrEmpty(Model.FilterColumn) && Model.Items.Count == 100)
            {
                <div class="alert alert-info">
                    ℹ️ Wyświetlono pierwsze 100 rekordów. Użyj filtrów powyżej, aby zawęzić wyniki.
                </div>
            }
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            @foreach (var col in Model.Config?.Columns ?? Enumerable.Empty<ColumnConfig>())
                            {
                                // Ukryj kolumnę FK, jeśli przeglądamy w kontekście rodzica
                                @if (!string.IsNullOrEmpty(Model.ParentEntity) && col.PropertyName == Model.FilterColumn)
                                {
                                    continue;
                                }
                                <th>@col.DisplayName</th>
                            }
                            <th style="width: 100px;">Akcje</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                @foreach (var col in Model.Config?.Columns ?? Enumerable.Empty<ColumnConfig>())
                                {
                                    // Ukryj kolumnę FK, jeśli przeglądamy w kontekście rodzica
                                    @if (!string.IsNullOrEmpty(Model.ParentEntity) && col.PropertyName == Model.FilterColumn)
                                    {
                                        continue; // Pomijamy kolumnę z FK do rodzica
                                    }

                                    @if (col.IsForeignKey && !string.IsNullOrEmpty(col.ForeignKeyNavigationProperty))
                                    {
                                        var navProp = Model.Config!.EntityType.GetProperty(col.ForeignKeyNavigationProperty);
                                        var navItem = navProp?.GetValue(item);
                                        
                                        if (navItem != null)
                                        {
                                            var fkConfig = ViewerRegistry.GetConfig(col.ForeignKeyEntity!);
                                            var description = EntityDescriptionHelper.GetDescription(navItem, fkConfig);
                                            <td>@description</td>
                                        }
                                        else
                                        {
                                            <td><em class="text-muted">-</em></td>
                                        }
                                    }
                                    else
                                    {
                                        var propValue = Model.Config!.EntityType.GetProperty(col.PropertyName)?.GetValue(item);
                                        <td>@propValue</td>
                                    }
                                }
                                <td>
                                    <div class="dropdown">
                                        <button class="btn btn-sm btn-outline-primary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                            ⚙️
                                        </button>
                                        <ul class="dropdown-menu">
                                            <li>
                                                @{
                                                    var idProp = Model.Config!.EntityType.GetProperty("Id");
                                                    var idValue = idProp?.GetValue(item);
                                                }
                                                <a class="dropdown-item" href="#" onclick="openEditModal('@Model.Entity', @idValue); return false;">
                                                    ✏️ Edycja
                                                </a>
                                            </li>
                                            @if (Model.Config?.ChildRelationships.Any() == true)
                                            {
                                                <li><hr class="dropdown-divider"></li>
                                                <li><h6 class="dropdown-header">Powiązane rekordy</h6></li>
                                                @foreach (var childRel in Model.Config.ChildRelationships)
                                                {
                                                    var childIdValue = idProp?.GetValue(item);
                                                    <li>
                                                        <a class="dropdown-item" href="/DbViewer/Browse?entity=@childRel.ChildEntityName&FilterColumn=@childRel.ForeignKeyPropertyName&FilterOperator=equals&FilterValue=@childIdValue&ParentEntity=@Model.Entity&ParentId=@childIdValue">
                                                            @childRel.ChildIcon @childRel.ChildDisplayName
                                                        </a>
                                                    </li>
                                                }
                                            }
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modal edycji -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="Save" id="editForm">
                <input type="hidden" name="entity" value="@Model.Entity" />
                <div class="modal-header">
                    <h5 class="modal-title">Edycja: @Model.Config?.Description</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="editFields">
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Anuluj</button>
                    <button type="submit" class="btn btn-primary">💾 Zapisz</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal wyszukiwania dla FK Huge -->
<div class="modal fade" id="searchModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="searchModalTitle">🔍 Wyszukiwanie</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <input type="text" class="form-control" id="searchInput" placeholder="Wpisz tekst do wyszukania...">
                </div>
                <div id="searchResults" style="max-height: 400px; overflow-y: auto;">
                    <div class="text-center text-muted">
                        <p>Wpisz co najmniej 3 znaki, aby rozpocząć wyszukiwanie</p>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Anuluj</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let configJson = null;
        let foreignKeyCache = {};
        
        @if (Model.ConfigDto != null)
        {
            <text>
            configJson = @Html.Raw(Model.ConfigDtoJson);
            console.log('✅ Config loaded:', configJson);
            </text>
        }
        else
        {
            <text>
            console.error('❌ ConfigDto is NULL!');
            </text>
        }

        async function loadForeignKeyOptions(entity) {
            if (foreignKeyCache[entity]) {
                return foreignKeyCache[entity];
            }

            try {
                const response = await fetch(`/DbViewer/Browse?handler=ForeignKeyOptions&entity=${entity}`);
                if (!response.ok) throw new Error(`HTTP ${response.status}`);
                
                const options = await response.json();
                foreignKeyCache[entity] = options;
                return options;
            } catch (error) {
                console.error(`Error loading FK options for ${entity}:`, error);
                return [];
            }
        }

        async function openEditModal(entity, id) {
            if (!configJson || !configJson.columns) {
                alert('Błąd: Brak konfiguracji słownika.');
                return;
            }

            try {
                const url = `/DbViewer/Browse?handler=Edit&entity=${entity}&id=${id}`;
                const response = await fetch(url);
                
                if (!response.ok) {
                    throw new Error(`HTTP ${response.status}`);
                }
                
                const data = await response.json();
                console.log('Data received:', data);
                
                const fieldsContainer = document.getElementById('editFields');
                fieldsContainer.innerHTML = '';

                const idValue = data.Id || data.id || id;
                fieldsContainer.innerHTML += `<input type="hidden" name="formData[Id]" value="${idValue}" />`;

                const editableColumns = configJson.columns.filter(col => col.isEditable);
                
                for (const col of editableColumns) {
                    const value = data[col.propertyName] 
                               || data[col.propertyName.charAt(0).toUpperCase() + col.propertyName.slice(1)]
                               || '';
                    
                    const required = col.isRequired ? 'required' : '';
                    const propertyNamePascal = col.propertyName.charAt(0).toUpperCase() + col.propertyName.slice(1);
                    
                    let fieldHtml = '';

                    if (col.isForeignKey && col.foreignKeyEntity) {
                        // Sprawdź tryb wyboru referencji
                        if (col.choiceMode === 'Huge') {
                            // Tryb HUGE - załaduj tylko opis dla aktualnej wartości
                            console.log(`Loading description for: ${col.foreignKeyEntity}, ID=${value}`);
                            let displayText = `ID: ${value}`;
                            
                            if (value) {
                                try {
                                    const descResponse = await fetch(`/DbViewer/Browse?handler=ForeignKeyDescription&entity=${col.foreignKeyEntity}&id=${value}`);
                                    if (descResponse.ok) {
                                        const descData = await descResponse.json();
                                        displayText = descData.text || displayText;
                                    }
                                } catch (error) {
                                    console.error(`Error loading description for ${col.foreignKeyEntity}:`, error);
                                }
                            }
                            
                            fieldHtml = `
                                <div class="mb-3">
                                    <label class="form-label">${col.displayName}</label>
                                    <div class="input-group">
                                        <input type="text" class="form-control" value="${displayText}" disabled id="fk_display_${propertyNamePascal}">
                                        <input type="hidden" name="formData[${propertyNamePascal}]" value="${value}" id="fk_${propertyNamePascal}">
                                        <button type="button" class="btn btn-outline-secondary" onclick="openSearchModal('${col.foreignKeyEntity}', '${propertyNamePascal}', '${col.displayName}')">
                                            🔍 Zmień
                                        </button>
                                    </div>
                                </div>
                            `;
                        } else {
                            // Tryb STANDARD - standardowa lista rozwijana
                            console.log(`Loading FK options for: ${col.foreignKeyEntity}`);
                            const options = await loadForeignKeyOptions(col.foreignKeyEntity);
                            
                            fieldHtml = `
                                <div class="mb-3">
                                    <label class="form-label">${col.displayName}</label>
                                    <select class="form-select" name="formData[${propertyNamePascal}]" ${required}>
                                        <option value="">-- Wybierz --</option>
                                        ${options.map(opt => 
                                            `<option value="${opt.id}" ${opt.id == value ? 'selected' : ''}>${opt.text}</option>`
                                        ).join('')}
                                    </select>
                                </div>
                            `;
                        }
                    } else {
                        fieldHtml = `
                            <div class="mb-3">
                                <label class="form-label">${col.displayName}</label>
                                <input type="text" class="form-control" 
                                       name="formData[${propertyNamePascal}]" 
                                       value="${value}" ${required}>
                            </div>
                        `;
                    }
                    
                    fieldsContainer.innerHTML += fieldHtml;
                }
                
                const modal = new bootstrap.Modal(document.getElementById('editModal'));
                modal.show();
            } catch (error) {
                console.error('Error in openEditModal:', error);
                alert('Błąd: ' + error.message);
            }
        }

        let currentSearchEntity = '';
        let currentSearchField = '';
        let searchTimeout = null;

        function openSearchModal(entity, fieldName, displayName) {
            currentSearchEntity = entity;
            currentSearchField = fieldName;
            
            document.getElementById('searchModalTitle').textContent = `🔍 Wyszukiwanie: ${displayName}`;
            document.getElementById('searchInput').value = '';
            document.getElementById('searchResults').innerHTML = '<div class="text-center text-muted"><p>Wpisz co najmniej 3 znaki, aby rozpocząć wyszukiwanie</p></div>';
            
            const searchModal = new bootstrap.Modal(document.getElementById('searchModal'));
            searchModal.show();
            
            // Nasłuchuj na wpisywanie
            document.getElementById('searchInput').oninput = (e) => {
                clearTimeout(searchTimeout);
                const query = e.target.value;
                
                if (query.length < 3) {
                    document.getElementById('searchResults').innerHTML = '<div class="text-center text-muted"><p>Wpisz co najmniej 3 znaki, aby rozpocząć wyszukiwanie</p></div>';
                    return;
                }
                
                searchTimeout = setTimeout(() => performSearch(query), 300);
            };
        }

        async function performSearch(query) {
            const resultsContainer = document.getElementById('searchResults');
            resultsContainer.innerHTML = '<div class="text-center"><div class="spinner-border" role="status"></div><p>Wyszukiwanie...</p></div>';
            
            try {
                const response = await fetch(`/DbViewer/Browse?handler=Search&entity=${currentSearchEntity}&query=${encodeURIComponent(query)}`);
                if (!response.ok) throw new Error(`HTTP ${response.status}`);
                
                const results = await response.json();
                
                if (results.length === 0) {
                    resultsContainer.innerHTML = '<div class="alert alert-info">Nie znaleziono wyników</div>';
                    return;
                }
                
                let html = '<div class="list-group">';
                results.forEach(item => {
                    html += `
                        <button type="button" class="list-group-item list-group-item-action" onclick="selectSearchResult(${item.id}, '${item.text.replace(/'/g, "\\'")}')">
                            ${item.text}
                        </button>
                    `;
                });
                html += '</div>';
                
                resultsContainer.innerHTML = html;
            } catch (error) {
                console.error('Search error:', error);
                resultsContainer.innerHTML = `<div class="alert alert-danger">Błąd wyszukiwania: ${error.message}</div>`;
            }
        }

        function selectSearchResult(id, text) {
            // Zaktualizuj wartości w formularzu edycji
            document.getElementById(`fk_${currentSearchField}`).value = id;
            document.getElementById(`fk_display_${currentSearchField}`).value = text;
            
            // Zamknij modal wyszukiwania
            const searchModal = bootstrap.Modal.getInstance(document.getElementById('searchModal'));
            searchModal.hide();
        }
    </script>
}