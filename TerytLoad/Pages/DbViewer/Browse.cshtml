@page
@model TerytLoad.Pages.DbViewer.BrowseModel
@using TerytLoad.Pages.DbViewer
@{
    ViewData["Title"] = Model.Config?.DisplayName ?? "Przeglądarka";
    if (Model.PickerMode) { Layout = "_PickerLayout"; }
}

<div class="container-fluid @(Model.PickerMode ? "" : "mt-4")">
@if (!Model.PickerMode)
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>@Model.Config?.Icon @Model.Config?.DisplayName</h2>
        <a href="/DbViewer" class="btn btn-secondary">← Powrót do menu</a>
    </div>
}

@* Kontekst rodzica (jeśli przeglądamy relację dziecko) *@
@if (!string.IsNullOrEmpty(Model.ParentEntity) && Model.ParentId.HasValue)
{
    <div class="alert alert-info">
        <strong>@ViewerRegistry.GetConfig(Model.ParentEntity)?.Icon @ViewerRegistry.GetConfig(Model.ParentEntity)?.DisplayName:</strong> 
        @Model.ParentDescription
        <span class="text-muted">(ID: @Model.ParentId)</span>
        <a href="/DbViewer/Browse?entity=@Model.ParentEntity" class="btn btn-sm btn-outline-primary ms-3">
            ← Powrót do @ViewerRegistry.GetConfig(Model.ParentEntity)?.DisplayName
        </a>
    </div>
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Formularz filtrowania -->
<div class="card mb-4">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0">🔍 Filtry</h5>
        <a href="/DbViewer/Browse?entity=@Model.Entity&ParentEntity=@Model.ParentEntity&ParentId=@Model.ParentId&PickerMode=@Model.PickerMode&PickerTargetField=@Model.PickerTargetField" class="btn btn-sm btn-outline-light">✕ Wyczyść filtry</a>
    </div>
    <div class="card-body">

            @* Serializacja aktywnych filtrów - zawsze obecna, camelCase dla JS *@
            <input type="hidden" id="filtersJson" value="@System.Text.Json.JsonSerializer.Serialize(Model.ActiveFilters, new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase })" />

            @* Odznaki aktywnych filtrów - zawsze obecny kontener, JS go wypełnia *@
            <div id="activeFilters" class="mb-3 d-flex flex-wrap gap-2 align-items-center"
                 style="@(Model.ActiveFilters.Any() ? "" : "display:none!important")"></div>

            @* Formularz dodawania nowego filtra *@
            <div class="row g-2 align-items-end">

                @* Spójnik i nawiasy - ukryte przy pierwszym filtrze, JS pokazuje od drugiego *@
                <div id="connectorGroup" class="col-auto" style="@(Model.ActiveFilters.Any() ? "" : "display:none!important")">
                    <label class="form-label">Spójnik</label>
                    <select id="newConnector" class="form-select form-select-sm" style="width:90px">
                        <option value="AND">AND</option>
                        <option value="OR">OR</option>
                    </select>
                </div>
                <div id="openParensGroup" class="col-auto" style="@(Model.ActiveFilters.Any() ? "" : "display:none!important")">
                    <label class="form-label">( przed</label>
                    <select id="newOpenParens" class="form-select form-select-sm" style="width:70px">
                        <option value="0">—</option>
                        <option value="1">(</option>
                        <option value="2">((</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Kolumna</label>
                    <select id="newColumn" class="form-select form-select-sm">
                        <option value="">-- Wybierz --</option>
                        @foreach (var opt in Model.FilterOptions)
                        {
                            <option value="@opt.FilterPath" data-label="@opt.DisplayLabel">@opt.DisplayLabel</option>
                        }
                    </select>
                </div>
                <div class="col-auto">
                    <label class="form-label">Operator</label>
                    <select id="newOperator" class="form-select form-select-sm" style="width:130px">
                        <option value="contains">zawiera</option>
                        <option value="notcontains">nie zawiera</option>
                        <option value="equals">równa się</option>
                        <option value="notequals">różni się</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Wartość</label>
                    <input type="text" id="newValue" class="form-control form-control-sm" placeholder="Wartość..."
                           onkeydown="if(event.key==='Enter'){addFilter();}">
                </div>

                <div id="closeParensGroup" class="col-auto" style="@(Model.ActiveFilters.Any() ? "" : "display:none!important")">
                    <label class="form-label">) po</label>
                    <select id="newCloseParens" class="form-select form-select-sm" style="width:70px">
                        <option value="0">—</option>
                        <option value="1">)</option>
                        <option value="2">))</option>
                    </select>
                </div>

                <div class="col-auto d-flex gap-2">
                    <button type="button" class="btn btn-outline-primary btn-sm" onclick="addFilter()">＋ Dodaj</button>
                    <button type="button" class="btn btn-primary btn-sm" onclick="applyFilters()">▶ Filtruj</button>
                </div>
            </div>

        </div>
    </div>

<!-- Tabela wyników -->
<div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">
                Tabela: @Model.Config?.Description
                <span class="text-muted">(@Model.Items.Count rekordów
                @if (!Model.ActiveFilters.Any())
                {
                    <text>- maksymalnie 100 pozycji, użyj filtra aby zobaczyć więcej</text>
                }
                )</span>
            </h5>
            @if (!Model.PickerMode)
            {
                <button type="button" class="btn btn-success btn-sm" onclick="openNewModal('@Model.Entity')">
                    ➕ Dodaj nowy
                </button>
            }
        </div>
        <div class="card-body">
            @if (!Model.ActiveFilters.Any() && Model.Items.Count == 100)
            {
                <div class="alert alert-info">
                    ℹ️ Wyświetlono pierwsze 100 rekordów. Użyj filtrów powyżej, aby zawęzić wyniki.
                </div>
            }
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            @foreach (var col in Model.Config?.Columns ?? Enumerable.Empty<ColumnConfig>())
                            {
                                // Ukryj kolumnę FK, jeśli przeglądamy w kontekście rodzica
                                @if (!string.IsNullOrEmpty(Model.ParentEntity) && col.PropertyName == Model.FilterColumn)
                                {
                                    continue;
                                }
                                @if (col.IsForeignKey)
                                {
                                    // Kolumny FK - nie sortujemy po ID, tylko po opisie (nie wspierane w SQL)
                                    <th>@col.DisplayName</th>
                                }
                                else
                                {
                                    var isSorted = Model.SortColumn == col.PropertyName;
                                    var nextDir = (isSorted && Model.SortDirection == "asc") ? "desc" : "asc";
                                    var icon = isSorted ? (Model.SortDirection == "asc" ? " ▲" : " ▼") : "";
                                    var filtersParam = System.Text.Json.JsonSerializer.Serialize(Model.ActiveFilters, new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase });
                                    var sortUrl = $"/DbViewer/Browse?entity={Model.Entity}&Filters={Uri.EscapeDataString(filtersParam)}&ParentEntity={Model.ParentEntity}&ParentId={Model.ParentId}&SortColumn={col.PropertyName}&SortDirection={nextDir}";
                                    if (Model.PickerMode) sortUrl += $"&PickerMode=true&PickerTargetField={Model.PickerTargetField}";
                                    <th><a href="@sortUrl" class="text-decoration-none text-dark">@col.DisplayName@icon</a></th>
                                }
                            }
                            <th style="width: 100px;">Akcje</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                @foreach (var col in Model.Config?.Columns ?? Enumerable.Empty<ColumnConfig>())
                                {
                                    // Ukryj kolumnę FK, jeśli przeglądamy w kontekście rodzica
                                    @if (!string.IsNullOrEmpty(Model.ParentEntity) && col.PropertyName == Model.FilterColumn)
                                    {
                                        continue; // Pomijamy kolumnę z FK do rodzica
                                    }

                                    @if (col.IsForeignKey && !string.IsNullOrEmpty(col.ForeignKeyNavigationProperty))
                                    {
                                        var navProp = Model.Config!.EntityType.GetProperty(col.ForeignKeyNavigationProperty);
                                        var navItem = navProp?.GetValue(item);
                                        
                                        if (navItem != null)
                                        {
                                            var fkConfig = ViewerRegistry.GetConfig(col.ForeignKeyEntity!);
                                            var description = EntityDescriptionHelper.GetDescription(navItem, fkConfig);
                                            <td>@description</td>
                                        }
                                        else
                                        {
                                            <td><em class="text-muted">-</em></td>
                                        }
                                    }
                                    else
                                    {
                                        var propValue = Model.Config!.EntityType.GetProperty(col.PropertyName)?.GetValue(item);
                                        <td>@propValue</td>
                                    }
                                }
                                <td>
                                    @{
                                        var idProp = Model.Config!.EntityType.GetProperty("Id");
                                        var idValue = idProp?.GetValue(item);
                                    }
                                    @if (Model.PickerMode)
                                    {
                                        <button class="btn btn-sm btn-success"
                                                onclick="pickerSelect(@idValue); return false;">
                                            ✔ Wybierz
                                        </button>
                                    }
                                    else
                                    {
                                        <div class="dropdown">
                                            <button class="btn btn-sm btn-outline-primary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                                ⚙️
                                            </button>
                                            <ul class="dropdown-menu">
                                                <li>
                                                    <a class="dropdown-item" href="#" onclick="openEditModal('@Model.Entity', @idValue); return false;">
                                                        ✏️ Edycja
                                                    </a>
                                                </li>
                                                @if (Model.Config?.ChildRelationships.Any() == true)
                                                {
                                                    <li><hr class="dropdown-divider"></li>
                                                    <li><h6 class="dropdown-header">Powiązane rekordy</h6></li>
                                                    @foreach (var childRel in Model.Config.ChildRelationships)
                                                    {
                                                        var childIdValue = idProp?.GetValue(item);
                                                        <li>
                                                            <a class="dropdown-item" href="/DbViewer/Browse?entity=@childRel.ChildEntityName&FilterColumn=@childRel.ForeignKeyPropertyName&FilterOperator=equals&FilterValue=@childIdValue&ParentEntity=@Model.Entity&ParentId=@childIdValue">
                                                                @childRel.ChildIcon @childRel.ChildDisplayName
                                                            </a>
                                                        </li>
                                                    }
                                                }
                                            </ul>
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@if (!Model.PickerMode)
{
<!-- Modal edycji -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="Save" id="editForm">
                <input type="hidden" name="entity" value="@Model.Entity" />
                <div class="modal-header">
                    <h5 class="modal-title" id="editModalTitle">Edycja: @Model.Config?.Description</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="editFields">
                </div>
                <div class="modal-footer justify-content-between">
                    <button type="button" class="btn btn-danger" id="deleteBtn" onclick="confirmDelete()">
                        🗑️ Usuń
                    </button>
                    <div>
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Anuluj</button>
                        <button type="submit" class="btn btn-primary">💾 Zapisz</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Ukryty formularz usuwania -->
<form method="post" asp-page-handler="Delete" id="deleteForm" style="display:none">
    <input type="hidden" name="entity" value="@Model.Entity" />
    <input type="hidden" name="id" id="deleteId" />
</form>

<!-- Modal wyszukiwania dla FK Huge -->
<div class="modal fade" id="searchModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="searchModalTitle">🔍 Wyszukiwanie</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <input type="text" class="form-control" id="searchInput" placeholder="Wpisz tekst do wyszukania...">
                </div>
                <div id="searchResults" style="max-height: 400px; overflow-y: auto;">
                    <div class="text-center text-muted">
                        <p>Wpisz co najmniej 3 znaki, aby rozpocząć wyszukiwanie</p>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Anuluj</button>
            </div>
        </div>
    </div>
</div>
} @* koniec @if (!Model.PickerMode) *@

@* Modal pickera (iframe z Browse w trybie PickerMode) *@
@if (!Model.PickerMode)
{
<div class="modal fade" id="pickerModal" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content" style="height:85vh">
            <div class="modal-header py-2">
                <h5 class="modal-title" id="pickerModalTitle">Wybierz rekord</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0" style="overflow:hidden">
                <iframe id="pickerIframe" src="" style="width:100%;height:100%;border:none"></iframe>
            </div>
        </div>
    </div>
</div>
}

@section Scripts {
    <script>
        let configJson = null;
        let foreignKeyCache = {};
        
        @if (Model.ConfigDto != null)
        {
            <text>
            configJson = @Html.Raw(Model.ConfigDtoJson);
            console.log('✅ Config loaded:', configJson);
            </text>
        }
        else
        {
            <text>
            console.error('❌ ConfigDto is NULL!');
            </text>
        }

        async function loadForeignKeyOptions(entity) {
            if (foreignKeyCache[entity]) {
                return foreignKeyCache[entity];
            }
            try {
                const response = await fetch(`/DbViewer/Browse?handler=ForeignKeyOptions&entity=${entity}`);
                if (!response.ok) throw new Error(`HTTP ${response.status}`);
                const options = await response.json();
                foreignKeyCache[entity] = options;
                return options;
            } catch (error) {
                console.error(`Error loading FK options for ${entity}:`, error);
                return [];
            }
        }

        @if (Model.PickerMode)
        {
            <text>
        // Tryb pickera: po wybraniu rekordu powiadamiamy okno nadrzędne
        function pickerSelect(id) {
            window.parent.pickerSelected(id, '@Model.Entity');
        }
            </text>
        }

        async function loadForeignKeyOptions(entity) {
            if (foreignKeyCache[entity]) {
                return foreignKeyCache[entity];
            }

            try {
                const response = await fetch(`/DbViewer/Browse?handler=ForeignKeyOptions&entity=${entity}`);
                if (!response.ok) throw new Error(`HTTP ${response.status}`);
                
                const options = await response.json();
                foreignKeyCache[entity] = options;
                return options;
            } catch (error) {
                console.error(`Error loading FK options for ${entity}:`, error);
                return [];
            }
        }

        async function openEditModal(entity, id) {
            if (!configJson || !configJson.columns) {
                alert('Błąd: Brak konfiguracji słownika.');
                return;
            }

            try {
                const url = `/DbViewer/Browse?handler=Edit&entity=${entity}&id=${id}`;
                const response = await fetch(url);
                
                if (!response.ok) {
                    throw new Error(`HTTP ${response.status}`);
                }
                
                const data = await response.json();
                
                const fieldsContainer = document.getElementById('editFields');
                fieldsContainer.innerHTML = '';

                const idValue = data.Id || data.id || id;
                fieldsContainer.innerHTML += `<input type="hidden" name="formData[Id]" value="${idValue}" />`;

                // Pokaż przycisk Usuń i ustaw ID do usunięcia
                document.getElementById('deleteBtn').style.display = '';
                document.getElementById('deleteId').value = idValue;
                document.getElementById('editModalTitle').textContent = `Edycja: ${configJson.description}`;

                await fillEditFields(data);

                const modal = new bootstrap.Modal(document.getElementById('editModal'));
                modal.show();
            } catch (error) {
                console.error('Error in openEditModal:', error);
                alert('Błąd: ' + error.message);
            }
        }

        async function openNewModal(entity) {
            if (!configJson || !configJson.columns) {
                alert('Błąd: Brak konfiguracji słownika.');
                return;
            }

            const fieldsContainer = document.getElementById('editFields');
            fieldsContainer.innerHTML = '';
            fieldsContainer.innerHTML += `<input type="hidden" name="formData[Id]" value="0" />`;

            // Ukryj przycisk Usuń dla nowego rekordu
            document.getElementById('deleteBtn').style.display = 'none';
            document.getElementById('editModalTitle').textContent = `Nowy rekord: ${configJson.description}`;

            await fillEditFields({});

            const modal = new bootstrap.Modal(document.getElementById('editModal'));
            modal.show();
        }

        async function fillEditFields(data) {
            const fieldsContainer = document.getElementById('editFields');
            const editableColumns = configJson.columns.filter(col => col.isEditable);

            for (const col of editableColumns) {
                    const value = data[col.propertyName] 
                               || data[col.propertyName.charAt(0).toUpperCase() + col.propertyName.slice(1)]
                               || '';
                    
                    const required = col.isRequired ? 'required' : '';
                    const propertyNamePascal = col.propertyName.charAt(0).toUpperCase() + col.propertyName.slice(1);
                    
                    let fieldHtml = '';

                    if (col.isForeignKey && col.foreignKeyEntity) {
                        // Sprawdź tryb wyboru referencji
                        if (col.choiceMode === 'Huge') {
                            // Tryb HUGE - załaduj tylko opis dla aktualnej wartości
                            let displayText = value ? `ID: ${value}` : '';
                            
                            if (value) {
                                try {
                                    const descResponse = await fetch(`/DbViewer/Browse?handler=ForeignKeyDescription&entity=${col.foreignKeyEntity}&id=${value}`);
                                    if (descResponse.ok) {
                                        const descData = await descResponse.json();
                                        displayText = descData.text || displayText;
                                    }
                                } catch (error) {
                                    console.error(`Error loading description for ${col.foreignKeyEntity}:`, error);
                                }
                            }
                            
                            fieldHtml = `
                                <div class="mb-3">
                                    <label class="form-label">${col.displayName}</label>
                                    <div class="input-group">
                                        <input type="text" class="form-control" value="${displayText}" disabled id="fk_display_${propertyNamePascal}">
                                        <input type="hidden" name="formData[${propertyNamePascal}]" value="${value}" id="fk_${propertyNamePascal}">
                                        <button type="button" class="btn btn-outline-secondary" onclick="openSearchModal('${col.foreignKeyEntity}', '${propertyNamePascal}', '${col.displayName}')">
                                            🔍 Zmień
                                        </button>
                                    </div>
                                </div>
                            `;
                        } else {
                            // Tryb STANDARD - standardowa lista rozwijana
                            const options = await loadForeignKeyOptions(col.foreignKeyEntity);
                            
                            fieldHtml = `
                                <div class="mb-3">
                                    <label class="form-label">${col.displayName}</label>
                                    <select class="form-select" name="formData[${propertyNamePascal}]" ${required}>
                                        <option value="">-- Wybierz --</option>
                                        ${options.map(opt => 
                                            `<option value="${opt.id}" ${opt.id == value ? 'selected' : ''}>${opt.text}</option>`
                                        ).join('')}
                                    </select>
                                </div>
                            `;
                        }
                    } else {
                        fieldHtml = `
                            <div class="mb-3">
                                <label class="form-label">${col.displayName}</label>
                                <input type="text" class="form-control" 
                                       name="formData[${propertyNamePascal}]" 
                                       value="${value}" ${required}>
                            </div>
                        `;
                    }
                    
                    
                    fieldsContainer.innerHTML += fieldHtml;
            }
        }

        function confirmDelete() {
            const idValue = document.getElementById('deleteId').value;
            if (confirm(`Czy na pewno chcesz usunąć rekord ID=${idValue}? Tej operacji nie można cofnąć.`)) {
                document.getElementById('deleteForm').submit();
            }
        }

        let currentSearchEntity = '';
        let currentSearchField = '';
        let searchTimeout = null;

        function openSearchModal(entity, fieldName, displayName) {
            // Otwórz Browse w trybie pickera w iframe
            const url = `/DbViewer/Browse?entity=${entity}&PickerMode=true&PickerTargetField=${fieldName}`;
            document.getElementById('pickerIframe').src = url;
            document.getElementById('pickerModalTitle').textContent = `Wybierz: ${displayName}`;

            currentSearchField = fieldName;
            const modal = new bootstrap.Modal(document.getElementById('pickerModal'));
            modal.show();
        }

        function pickerSelected(id, entity) {
            // Wywołane przez iframe po wyborze rekordu
            const fieldName = currentSearchField;

            // Pobierz opis wybranego rekordu
            fetch(`/DbViewer/Browse?handler=ForeignKeyDescription&entity=${entity}&id=${id}`)
                .then(r => r.json())
                .then(data => {
                    document.getElementById(`fk_${fieldName}`).value = id;
                    document.getElementById(`fk_display_${fieldName}`).value = data.text || `ID: ${id}`;
                })
                .catch(() => {
                    document.getElementById(`fk_${fieldName}`).value = id;
                    document.getElementById(`fk_display_${fieldName}`).value = `ID: ${id}`;
                });

            // Zamknij modal pickera
            bootstrap.Modal.getInstance(document.getElementById('pickerModal')).hide();
        }

        // ── Filtry ────────────────────────────────────────────────────────────

        let activeFilters = JSON.parse(document.getElementById('filtersJson')?.value || '[]');

        // Wyrenderuj filtry odczytane z URL przy załadowaniu strony
        renderFilterBadges();

        function addFilter() {
            const column   = document.getElementById('newColumn');
            const operator = document.getElementById('newOperator');
            const value    = document.getElementById('newValue');

            if (!column.value) { alert('Wybierz kolumnę.'); return; }
            if (!value.value.trim()) { alert('Podaj wartość.'); return; }

            const label = column.options[column.selectedIndex].dataset.label || column.value;

            const connector   = document.getElementById('newConnector')?.value   ?? 'AND';
            const openParens  = parseInt(document.getElementById('newOpenParens')?.value  ?? '0');
            const closeParens = parseInt(document.getElementById('newCloseParens')?.value ?? '0');

            activeFilters.push({
                connector:   connector,
                openParens:  openParens,
                column:      column.value,
                operator:    operator.value,
                value:       value.value.trim(),
                closeParens: closeParens,
                columnLabel: label
            });

            // Wyczyść pola
            column.value  = '';
            value.value   = '';
            if (document.getElementById('newOpenParens'))  document.getElementById('newOpenParens').value  = '0';
            if (document.getElementById('newCloseParens')) document.getElementById('newCloseParens').value = '0';

            renderFilterBadges();
        }

        function removeFilter(index) {
            activeFilters.splice(index, 1);
            // Pierwszy filtr nie ma spójnika
            if (activeFilters.length > 0) activeFilters[0].connector = 'AND';
            renderFilterBadges();
        }

        function renderFilterBadges() {
            const container = document.getElementById('activeFilters');
            const hasFilters = activeFilters.length > 0;

            // Pokaż/ukryj kontener odznak
            container.style.display = hasFilters ? '' : 'none';

            // Pokaż/ukryj spójnik i nawiasy (tylko od drugiego filtra)
            ['connectorGroup', 'openParensGroup', 'closeParensGroup'].forEach(id => {
                document.getElementById(id).style.display = hasFilters ? '' : 'none';
            });

            // Zbuduj odznaki
            let html = '';
            activeFilters.forEach((f, i) => {
                if (i > 0) html += `<span class="badge bg-secondary">${f.connector}</span>`;
                for (let p = 0; p < f.openParens;  p++) html += `<span class="text-muted fw-bold fs-5">(</span>`;
                const opLabel = {contains:'zawiera',notcontains:'nie zawiera',equals:'=',notequals:'≠'}[f.operator] ?? f.operator;
                html += `<span class="badge bg-primary d-flex align-items-center gap-1 fs-6 px-2 py-1">
                            ${f.columnLabel} ${opLabel} &ldquo;${f.value}&rdquo;
                            <button type="button" class="btn-close btn-close-white btn-sm ms-1"
                                    style="font-size:0.6rem"
                                    onclick="removeFilter(${i})"
                                    title="Usuń filtr"></button>
                         </span>`;
                for (let p = 0; p < f.closeParens; p++) html += `<span class="text-muted fw-bold fs-5">)</span>`;
            });
            container.innerHTML = html;

            // Zaktualizuj ukryte pole z JSON
            document.getElementById('filtersJson').value = JSON.stringify(activeFilters);
        }

        function applyFilters() {
            const json        = JSON.stringify(activeFilters);
            const entity      = '@Model.Entity';
            const sort        = '@Model.SortColumn';
            const dir         = '@Model.SortDirection';
            const parent      = '@Model.ParentEntity';
            const pid         = '@Model.ParentId';
            const pickerMode  = '@Model.PickerMode'.toLowerCase();
            const pickerField = '@Model.PickerTargetField';

            let url = `/DbViewer/Browse?entity=${entity}&Filters=${encodeURIComponent(json)}`;
            if (sort)        url += `&SortColumn=${sort}&SortDirection=${dir}`;
            if (parent)      url += `&ParentEntity=${parent}&ParentId=${pid}`;
            if (pickerMode === 'true') url += `&PickerMode=true&PickerTargetField=${pickerField}`;
            window.location.href = url;
        }
    </script>
}