@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<div class="text-center mt-5">
    <h1 class="display-4">🗺️ System zarządzania danymi TERYT</h1>
    <p class="lead">Aplikacja do ładowania i przeglądania danych TERYT (Terc, Simc, Ulic) oraz kodów pocztowych</p>
</div>

<div class="row mt-5">
    <!-- Karta 1: Ładowanie danych -->
    <div class="col-md-4 mb-4">
        <div class="card h-100 shadow-sm border-primary">
            <div class="card-header bg-primary text-white">
                <h5 class="card-title mb-0">
                    <i class="bi bi-download"></i> Ładowanie danych
                </h5>
            </div>
            <div class="card-body">
                <p class="card-text">
                    Załaduj dane z plików TERYT do bazy danych.
                </p>
                <a asp-page="/LoadData" class="btn btn-primary w-100">
                    <i class="bi bi-upload"></i> Załaduj dane
                </a>
            </div>
            <div class="card-footer text-muted">
                <small>
                    <i class="bi bi-info-circle"></i> Import Terc, Simc, Ulic
                </small>
            </div>
        </div>
    </div>

    <!-- Karta 2: Ładowanie kodów pocztowych -->
    <div class="col-md-4 mb-4">
        <div class="card h-100 shadow-sm border-success">
            <div class="card-header bg-success text-white">
                <h5 class="card-title mb-0">
                    <i class="bi bi-mailbox"></i> Kody pocztowe
                </h5>
            </div>
            <div class="card-body">
                <p class="card-text">
                    Załaduj kody pocztowe z pliku PNA do bazy danych.
                </p>
                <a asp-page="/LoadPostalCodes" class="btn btn-success w-100">
                    <i class="bi bi-envelope"></i> Załaduj kody
                </a>
            </div>
            <div class="card-footer text-muted">
                <small>
                    <i class="bi bi-info-circle"></i> Import z pliku PNA
                </small>
            </div>
        </div>
    </div>

    <!-- Karta 3: Przeglądarka hierarchiczna -->
    <div class="col-md-4 mb-4">
        <div class="card h-100 shadow-sm border-info">
            <div class="card-header bg-info text-white">
                <h5 class="card-title mb-0">
                    <i class="bi bi-diagram-3"></i> Przeglądarka
                </h5>
            </div>
            <div class="card-body">
                <p class="card-text">
                    Przeglądaj dane w strukturze hierarchicznej.
                </p>
                <a asp-page="/Browse" class="btn btn-info w-100">
                    <i class="bi bi-tree"></i> Przeglądaj hierarchię
                </a>
            </div>
            <div class="card-footer text-muted">
                <small>
                    <i class="bi bi-info-circle"></i> Woj → Pow → Gm → Miej → Ul
                </small>
            </div>
        </div>
    </div>

    <!-- Karta 4: Przeglądarka TERYT -->
    <div class="col-md-4 mb-4">
        <div class="card h-100 shadow-sm border-secondary">
            <div class="card-header bg-secondary text-white">
                <h5 class="card-title mb-0">
                    <i class="bi bi-table"></i> TERYT Raw
                </h5>
            </div>
            <div class="card-body">
                <p class="card-text">
                    Przeglądaj surowe dane z tabel TERYT.
                </p>
                <a asp-page="/BrowseTeryt" class="btn btn-secondary w-100">
                    <i class="bi bi-database"></i> Dane surowe
                </a>
            </div>
            <div class="card-footer text-muted">
                <small>
                    <i class="bi bi-info-circle"></i> Terc, Simc, Ulic
                </small>
            </div>
        </div>
    </div>

    <!-- Karta 5: Wyszukiwarka -->
    <div class="col-md-4 mb-4">
        <div class="card h-100 shadow-sm border-dark">
            <div class="card-header bg-dark text-white">
                <h5 class="card-title mb-0">
                    <i class="bi bi-search"></i> Wyszukiwarka
                </h5>
            </div>
            <div class="card-body">
                <p class="card-text">
                    Wyszukaj kod pocztowy dla danego adresu.
                </p>
                <a asp-page="/Szukaj" class="btn btn-dark w-100">
                    <i class="bi bi-search"></i> Szukaj adresu
                </a>
            </div>
            <div class="card-footer text-muted">
                <small>
                    <i class="bi bi-info-circle"></i> Wyszukiwanie adresów
                </small>
            </div>
        </div>
    </div>

    <!-- Karta 6: Weryfikacja adresów -->
    <div class="col-md-4 mb-4">
        <div class="card h-100 shadow-sm border-danger">
            <div class="card-header bg-danger text-white">
                <h5 class="card-title mb-0">
                    <i class="bi bi-shield-check"></i> Weryfikacja
                </h5>
            </div>
            <div class="card-body">
                <p class="card-text">
                    Zweryfikuj poprawność adresów z pliku CSV.
                </p>
                <a asp-page="/VerifyAddresses" class="btn btn-danger w-100">
                    <i class="bi bi-check-circle"></i> Weryfikuj adresy
                </a>
            </div>
            <div class="card-footer text-muted">
                <small>
                    <i class="bi bi-info-circle"></i> Masowa walidacja
                </small>
            </div>
        </div>
    </div>

    <!-- NOWA KARTA 7: Weryfikacja zakresów kodów pocztowych -->
    <div class="col-md-4 mb-4">
        <div class="card h-100 shadow-sm border-warning">
            <div class="card-header bg-warning text-dark">
                <h5 class="card-title mb-0">
                    <i class="bi bi-check2-square"></i> Weryfikacja zakresów
                </h5>
            </div>
            <div class="card-body">
                <p class="card-text">
                    Sprawdź czy zakresy numerów domów w kodach pocztowych nie nakładają się.
                </p>
                <a asp-page="/VerifyPostalCodes" class="btn btn-warning w-100">
                    <i class="bi bi-play-fill"></i> Weryfikuj zakresy
                </a>
            </div>
            <div class="card-footer text-muted">
                <small>
                    <i class="bi bi-info-circle"></i> Wykrywa konflikty numeracji
                </small>
            </div>
        </div>
    </div>
</div>

<div class="mt-5 text-center">
    <div class="alert alert-light border">
        <h5><i class="bi bi-lightbulb"></i> Kolejność działań</h5>
        <ol class="text-start d-inline-block">
            <li>Załaduj dane TERYT (Terc, Simc, Ulic)</li>
            <li>Załaduj kody pocztowe z pliku PNA</li>
            <li><strong class="text-warning">Zweryfikuj zakresy numerów (NOWOŚĆ!)</strong></li>
            <li>Przeglądaj dane lub wyszukuj adresy</li>
            <li>Weryfikuj adresy z pliku CSV</li>
        </ol>
    </div>
</div>

<style>
    .card {
        transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
    }
    
    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 16px rgba(0,0,0,0.2) !important;
    }
    
    .btn {
        transition: all 0.2s ease-in-out;
    }
    
    .btn:hover {
        transform: scale(1.05);
    }
</style>