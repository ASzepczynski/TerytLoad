@page
@model TerytLoad.Pages.ValidateTerytUlicPoprawkiModel
@{
    ViewData["Title"] = "Walidacja TerytUlic";
}

<h1>@ViewData["Title"]</h1>

<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0">Walidacja TerytUlic względem słownika TerytUlicPoprawki.xlsx</h5>
    </div>
    <div class="card-body">
        <p class="text-muted">
            Ta funkcja porównuje wszystkie wpisy z tabeli <strong>TerytUlic</strong> ze słownikiem 
            <code>AppData/Dictionaries/TerytUlicPoprawki.xlsx</code> i loguje różnice do 
            <code>AppData/Logs/TerytUlic.txt</code>
        </p>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">
                <i class="bi bi-exclamation-triangle"></i>
                <strong>Błąd:</strong> @Model.ErrorMessage
            </div>
        }

        @if (!Model.ShowResults)
        {
            <form method="post" id="validateForm">
                <button type="submit" class="btn btn-primary btn-lg" id="btnValidate">
                    <i class="bi bi-check-circle"></i> Rozpocznij walidację
                </button>
                <div id="loadingSpinner" class="mt-3" style="display: none;">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Ładowanie...</span>
                    </div>
                    <span class="ms-2">Trwa walidacja, proszę czekać...</span>
                </div>
            </form>
        }
    </div>
</div>

@if (Model.ShowResults)
{
    <div class="card">
        <div class="card-header bg-success text-white">
            <h5 class="mb-0">✓ Zakończono walidację</h5>
        </div>
        <div class="card-body">
            <table class="table">
                <tbody>
                    <tr>
                        <th>Przetworzonych wpisów:</th>
                        <td>@Model.TotalCount</td>
                    </tr>
                    <tr>
                        <th>Znaleziono w słowniku:</th>
                        <td class="text-success fw-bold">@Model.FoundCount</td>
                    </tr>
                    <tr>
                        <th>Brak w słowniku:</th>
                        <td class="text-danger fw-bold">@Model.NotFoundCount</td>
                    </tr>
                    <tr>
                        <th>Procent pokrycia:</th>
                        <td>
                            @{
                                var coverage = Model.TotalCount > 0 ? (Model.FoundCount * 100.0 / Model.TotalCount) : 0;
                            }
                            <span class="@(coverage >= 95 ? "text-success" : coverage >= 80 ? "text-warning" : "text-danger") fw-bold">
                                @coverage.ToString("F2")%
                            </span>
                        </td>
                    </tr>
                </tbody>
            </table>

            <div class="alert alert-info mt-3">
                <i class="bi bi-info-circle"></i>
                Szczegółowy log: <code>@Model.LogFilePath</code>
            </div>

            <a href="@Url.Page("/ValidateTerytUlicPoprawki")" class="btn btn-secondary">
                <i class="bi bi-arrow-counterclockwise"></i> Uruchom ponownie
            </a>
        </div>
    </div>
}

@section Scripts {
    <script>
        document.getElementById('validateForm')?.addEventListener('submit', function() {
            document.getElementById('btnValidate').disabled = true;
            document.getElementById('loadingSpinner').style.display = 'block';
        });
    </script>
}