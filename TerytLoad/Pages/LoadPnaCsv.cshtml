@page
@model TerytLoad.Pages.LoadPnaCsvModel
@{
    ViewData["Title"] = "Ładowanie danych PNA z CSV";
}

<div class="container mt-4">
    <h1 class="mb-4">📄 Ładowanie danych PNA z pliku CSV</h1>

    @if (!string.IsNullOrEmpty(Model.Message))
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            <pre style="white-space: pre-wrap; margin: 0; font-family: 'Courier New', monospace; font-size: 14px;">@Model.Message</pre>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card mb-4">
        <div class="card-header bg-primary text-white">
            <h3 class="mb-0">📁 Załaduj dane PNA z pliku CSV</h3>
        </div>
        <div class="card-body">
            <p class="card-text">Kliknij poniżej, aby:</p>
            <ol>
                <li>Znaleźć plik <code>spispna-cz1.txt</code> w folderze <code>AppData\pna</code></li>
                <li>Przetworzyć dane z pliku CSV (kodowanie CP-1250)</li>
                <li>Wyczyścić tabelę <strong>Pna</strong></li>
                <li>Załadować nowe dane do tabeli <strong>Pna</strong></li>
            </ol>
            <p class="text-muted">
                <strong>Uwaga:</strong> Proces może potrwać kilka minut w zależności od rozmiaru pliku CSV.
            </p>
            <form method="post" asp-page-handler="LoadCsv">
                <button type="submit" class="btn btn-primary btn-lg">
                    <span>📤</span> Załaduj dane z CSV
                </button>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-header bg-info text-white">
            <h5 class="mb-0">ℹ️ Informacje</h5>
        </div>
        <div class="card-body">
            <p><strong>Folder źródłowy:</strong> <code>AppData\pna</code> (w katalogu projektu)</p>
            <p><strong>Nazwa pliku:</strong> <code>spispna-cz1.txt</code></p>
            <p><strong>Kodowanie:</strong> CP-1250 (Windows-1250)</p>
            <p><strong>Tabela docelowa:</strong> <strong>Pna</strong></p>
            <p class="mb-0"><strong>Format CSV:</strong> Kod;Miasto;Dzielnica;Ulica;Gmina;Powiat;Województwo;Numery</p>
        </div>
    </div>

    <div class="mt-4">
        <a asp-page="/Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Powrót do strony głównej
        </a>
    </div>
</div>