@page
@model TerytLoad.Pages.LoadTypyUlicModel
@{
    ViewData["Title"] = "Ładowanie TypyUlic";
}

<h1>@ViewData["Title"]</h1>

<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0">Ładowanie TypyUlic z słownika do bazy danych</h5>
    </div>
    <div class="card-body">
        <p class="text-muted">
            Ta funkcja porównuje wszystkie wpisy z tabeli <strong>TerytUlic</strong> ze słownikiem
            <code>AppData/Dictionaries/TypyUlic.xlsx</code> i ładuje je do tabeli <strong>TypyUlic</strong>.
            Logi są zapisywane do <code>AppData/Logs/LoadTypyUlic.txt</code>
        </p>

        @if (!Model.IsProcessing)
        {
            <form method="post">
                <button type="submit" class="btn btn-primary btn-lg">
                    <i class="bi bi-download"></i> Rozpocznij ładowanie
                </button>
            </form>
        }
        else
        {
            <div class="alert alert-info">
                <strong>Trwa ładowanie...</strong>
                <div class="progress mt-2">
                    <div class="progress-bar progress-bar-striped progress-bar-animated"
                         role="progressbar"
                         style="width: @Model.ProgressPercentage%"
                         aria-valuenow="@Model.ProgressPercentage"
                         aria-valuemin="0"
                         aria-valuemax="100">
                        @Model.ProgressPercentage%
                    </div>
                </div>
                <p class="mt-2 mb-0">@Model.CurrentOperation</p>
            </div>
        }
    </div>
</div>

@if (Model.ShowResults)
{
    <div class="card">
        <div class="card-header bg-success text-white">
            <h5 class="mb-0">✓ Zakończono ładowanie</h5>
        </div>
        <div class="card-body">
            <table class="table">
                <tbody>
                    <tr>
                        <th>Przetworzonych wpisów:</th>
                        <td>@Model.TotalCount</td>
                    </tr>
                    <tr>
                        <th>Znaleziono w słowniku:</th>
                        <td class="text-success fw-bold">@Model.FoundCount</td>
                    </tr>
                    <tr>
                        <th>Brak w słowniku:</th>
                        <td class="text-danger fw-bold">@Model.NotFoundCount</td>
                    </tr>
                    <tr>
                        <th>Procent pokrycia:</th>
                        <td>
                            @{
                                var coverage = Model.TotalCount > 0 ? (Model.FoundCount * 100.0 / Model.TotalCount) : 0;
                            }
                            <span class="@(coverage >= 95 ? "text-success" : coverage >= 80 ? "text-warning" : "text-danger") fw-bold">
                                @coverage.ToString("F2")%
                            </span>
                        </td>
                    </tr>
                </tbody>
            </table>

            <div class="alert alert-info mt-3">
                <i class="bi bi-info-circle"></i>
                Szczegółowy log: <code>@Model.LogFilePath</code>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        // Auto-refresh co 2 sekundy podczas przetwarzania
        @if (Model.IsProcessing)
        {
            <text>
            setTimeout(function() {
                location.reload();
            }, 2000);
            </text>
        }
    </script>
}