@page
@model TerytLoad.Pages.ExportToExcelModel
@{
    ViewData["Title"] = "Eksport do Excel";
}

<h1>@ViewData["Title"]</h1>

<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0">📊 Eksport tabeli z bazy danych do pliku Excel</h5>
    </div>
    <div class="card-body">
        <p class="text-muted">
            Wybierz tabelę z bazy danych <strong>Address</strong>, którą chcesz wyeksportować do pliku Excel.
            Plik zostanie zapisany w folderze <code>AppData/Export/</code> z nagłówkami kolumn.
        </p>

        @if (!Model.IsProcessing)
        {
            <form method="post">
                <div class="mb-3">
                    <label for="SelectedTable" class="form-label">Wybierz tabelę do eksportu:</label>
                    <select asp-for="SelectedTable" 
                            asp-items="Model.AvailableTables" 
                            class="form-select form-select-lg"
                            required>
                    </select>
                    <span asp-validation-for="SelectedTable" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary btn-lg">
                    <i class="bi bi-file-earmark-spreadsheet"></i> Eksportuj do Excel
                </button>
            </form>
        }
        else
        {
            <div class="alert alert-info">
                <strong>Trwa eksport...</strong>
                <div class="progress mt-2">
                    <div class="progress-bar progress-bar-striped progress-bar-animated"
                         role="progressbar"
                         style="width: @Model.ProgressPercentage%"
                         aria-valuenow="@Model.ProgressPercentage"
                         aria-valuemin="0"
                         aria-valuemax="100">
                        @Model.ProgressPercentage%
                    </div>
                </div>
                <p class="mt-2 mb-0">@Model.CurrentOperation</p>
            </div>
        }
    </div>
</div>

@if (Model.ShowResults)
{
    <div class="card">
        <div class="card-header bg-success text-white">
            <h5 class="mb-0">✓ Eksport zakończony pomyślnie</h5>
        </div>
        <div class="card-body">
            <table class="table">
                <tbody>
                    <tr>
                        <th>Tabela:</th>
                        <td><strong>@Model.SelectedTable</strong></td>
                    </tr>
                    <tr>
                        <th>Liczba rekordów:</th>
                        <td class="text-success fw-bold">@Model.TotalCount</td>
                    </tr>
                    <tr>
                        <th>Nazwa pliku:</th>
                        <td><code>@Model.OutputFileName</code></td>
                    </tr>
                    <tr>
                        <th>Lokalizacja:</th>
                        <td><code>AppData/Export/@Model.OutputFileName</code></td>
                    </tr>
                </tbody>
            </table>

            <div class="alert alert-success mt-3">
                <i class="bi bi-check-circle"></i>
                Plik Excel został utworzony pomyślnie i zawiera nagłówki kolumn oraz wszystkie dane z wybranej tabeli.
            </div>

            <a asp-page="/ExportToExcel" class="btn btn-primary mt-2">
                <i class="bi bi-arrow-repeat"></i> Eksportuj kolejną tabelę
            </a>
            <a asp-page="/Index" class="btn btn-secondary mt-2">
                <i class="bi bi-arrow-left"></i> Powrót do strony głównej
            </a>
        </div>
    </div>
}

@section Scripts {
    <script>
        // Auto-refresh co 2 sekundy podczas przetwarzania
        @if (Model.IsProcessing)
        {
            <text>
            setTimeout(function() {
                location.reload();
            }, 2000);
            </text>
        }
    </script>
    <partial name="_ValidationScriptsPartial" />
}