<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - System TERYT</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TerytLoad.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">System TERYT</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Index">Strona główna</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Database">Baza danych</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/BuildHierarchy">Struktura hierarchiczna</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-dark" href="#" id="pnaDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Dane PNA
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="pnaDropdown">
                                <li><a class="dropdown-item" asp-area="" asp-page="/LoadPnaCsv">📄 Ładuj z CSV</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-page="/LoadPdf">📕 Ładuj z PDF (stare)</a></li>
                            </ul>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/LoadPostalCodes">Kody pocztowe</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Browse">Przeglądarka</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/BrowseTeryt">TERYT</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-dark" href="#" id="searchDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Wyszukiwanie
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="searchDropdown">
                                <li><a class="dropdown-item" asp-area="" asp-page="/Szukaj">🔍 Pojedyncze</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-page="/VerifyAddresses">✔️ Masowa weryfikacja</a></li>
                            </ul>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Tools/FilterAddresses">🧹 Filtruj adresy (błędy)</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/ProcessTaxOffices">🏢 Urzędy Skarbowe</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-page="/LoadTypyUlic">Typy Ulic</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-page="/ValidateTypyUlic">Walidacja Typów Ulic</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            <div class="row">
                <div class="col-md-6">
                    &copy; 2025-2026 <strong>Andrzej Szepczyński</strong> - System zarządzania danymi TERYT
                </div>
                <div class="col-md-6 text-end">
                    <a asp-area="" asp-page="/Index">Strona główna</a> |
                    <a asp-area="" asp-page="/Database">Baza danych</a> |
                    <a asp-area="" asp-page="/Browse">Przeglądarka</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>