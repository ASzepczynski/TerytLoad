<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - System TERYT</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TerytLoad.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">
                    <i class="bi bi-house-fill"></i> System TERYT
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        
                        <!-- 1. Strona główna -->
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Index">
                                <i class="bi bi-house"></i> Strona główna
                            </a>
                        </li>

                        <!-- 2. Przeglądanie danych -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-dark" href="#" id="browseDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-eye"></i> Przeglądanie danych
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="browseDropdown">
                                <li><a class="dropdown-item" asp-page="/BrowseTeryt"><i class="bi bi-map"></i> Przeglądarka TERYT</a></li>
                                <li><a class="dropdown-item" asp-page="/Browse"><i class="bi bi-diagram-3"></i> Przeglądarka hierarchii</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" asp-page="/DbViewer/Index"><i class="bi bi-journals"></i> Słowniki</a></li>
                            </ul>
                        </li>

                        <!-- 3. Ładowanie danych -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-dark" href="#" id="loadDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-download"></i> Ładowanie
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="loadDropdown">
                                <li><h6 class="dropdown-header">Dane TERYT</h6></li>
                                <li><a class="dropdown-item" asp-page="/Database"><i class="bi bi-table"></i> Ładuj dane TERYT</a></li>
                                <li><a class="dropdown-item" asp-page="/LoadTerytUlicPoprawki"><i class="bi bi-signpost-split"></i> Słowniki ulic (Poprawki + Typy)</a></li>
                                <li><a class="dropdown-item" asp-page="/BuildHierarchy"><i class="bi bi-diagram-3-fill"></i> Buduj strukturę hierarchiczną</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><h6 class="dropdown-header">Kody pocztowe</h6></li>
                                <li><a class="dropdown-item" asp-page="/LoadPostalCodes"><i class="bi bi-mailbox"></i> Kody pocztowe</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><h6 class="dropdown-header">Słowniki</h6></li>
                                <li><a class="dropdown-item" asp-page="/ProcessTaxOffices"><i class="bi bi-building"></i> Urzędy skarbowe</a></li>
                            </ul>
                        </li>

                        <!-- 4. Baza danych -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-dark" href="#" id="databaseDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-database"></i> Baza danych
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="databaseDropdown">
                                <li><a class="dropdown-item text-danger" asp-page="/Database"><i class="bi bi-trash"></i> Usuń bazę danych</a></li>
                                <li><a class="dropdown-item text-warning" asp-page="/Database"><i class="bi bi-eraser"></i> Wyczyść dane</a></li>
                            </ul>
                        </li>

                        <!-- 5. Przetwarzanie danych -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-dark" href="#" id="processDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-gear"></i> Przetwarzanie
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="processDropdown">
                                <li><h6 class="dropdown-header">Wyszukiwanie</h6></li>
                                <li><a class="dropdown-item" asp-page="/Szukaj"><i class="bi bi-search"></i> Szukanie pojedyncze</a></li>
                                <li><a class="dropdown-item" asp-page="/VerifyAddresses"><i class="bi bi-check2-square"></i> Masowa weryfikacja adresów</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><h6 class="dropdown-header">Narzędzia</h6></li>
                                <li><a class="dropdown-item" asp-page="/Tools/FilterAddresses"><i class="bi bi-funnel"></i> Filtruj adresy (błędy)</a></li>
                                <li><a class="dropdown-item" asp-page="/ValidateTerytUlicPoprawki"><i class="bi bi-check-circle"></i> Walidacja typów ulic</a></li>
                                <li><a class="dropdown-item" asp-page="/VerifyPostalCodes"><i class="bi bi-mailbox2"></i> Weryfikacja kodów pocztowych</a></li>
                                <li><a class="dropdown-item" asp-page="/ExportToExcel"><i class="bi bi-file-earmark-excel"></i> Eksport do Excel</a></li>
                            </ul>
                        </li>



                    </ul>
                </div>
            </div>
        </nav>
    </header>
    
    <div class="container-fluid px-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            <div class="row">
                <div class="col-md-6">
                    &copy; 2025-2026 <strong>Andrzej Szepczyński</strong> - System zarządzania danymi TERYT
                </div>
                <div class="col-md-6 text-end">
                    <a asp-area="" asp-page="/Index">Strona główna</a> |
                    <a asp-area="" asp-page="/Database">Baza danych</a> |
                    <a asp-area="" asp-page="/Browse">Przeglądarka</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>