@page
@model TerytLoad.Pages.LoadPdfModel
@{
    ViewData["Title"] = "Ładowanie danych PNA z PDF";
}

<div class="container mt-4">
    <h1 class="mb-4">📄 Ładowanie danych PNA z pliku PDF</h1>

    @if (!string.IsNullOrEmpty(Model.Message))
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            <pre style="white-space: pre-wrap; margin: 0; font-family: 'Courier New', monospace; font-size: 14px;">@Model.Message</pre>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card mb-4">
        <div class="card-header bg-primary text-white">
            <h3 class="mb-0">📁 Załaduj dane PNA z pliku PDF</h3>
        </div>
        <div class="card-body">
            <p class="card-text">Kliknij poniżej, aby:</p>
            <ol>
                <li>Znaleźć plik <code>pna.pdf</code> w folderze <code>AppData\Teryt</code></li>
                <li>Przetworzyć dane z pliku PDF</li>
                <li>Wyczyścić tabelę <strong>Pna</strong></li>
                <li>Załadować nowe dane do tabeli <strong>Pna</strong></li>
            </ol>
            <p class="text-muted">
                <strong>Uwaga:</strong> Proces może potrwać kilka minut w zależności od rozmiaru pliku PDF.
            </p>
            <form method="post" asp-page-handler="LoadPdf">
                <button type="submit" class="btn btn-primary btn-lg">
                    <span>📤</span> Załaduj dane z PDF
                </button>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-header bg-info text-white">
            <h5 class="mb-0">ℹ️ Informacje</h5>
        </div>
        <div class="card-body">
            <p><strong>Folder źródłowy:</strong> <code>AppData\Teryt</code> (w katalogu projektu)</p>
            <p><strong>Nazwa pliku:</strong> <code>pna.pdf</code></p>
            <p><strong>Tabela docelowa:</strong> <strong>Pna</strong></p>
            <p class="mb-0"><strong>Struktura danych PNA:</strong></p>
            <ul class="mb-0">
                <li>Kod pocztowy</li>
                <li>Miasto</li>
                <li>Dzielnica</li>
                <li>Ulica</li>
                <li>Numery budynków</li>
                <li>Gmina</li>
                <li>Powiat</li>
                <li>Województwo</li>
            </ul>
        </div>
    </div>
</div>